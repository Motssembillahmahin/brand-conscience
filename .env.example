# Meta Marketing API
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=

# Google Gemini
GEMINI_API_KEY=

# Slack
SLACK_BOT_TOKEN=
SLACK_CHANNEL_OPS=#brand-conscience-ops
SLACK_CHANNEL_APPROVALS=#brand-conscience-approvals

# OPIK (optional for self-hosted)
OPIK_API_KEY=
