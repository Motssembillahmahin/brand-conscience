# All env vars use BC_ prefix with __ (double underscore) for nesting.
# Example: BC_META__APP_ID maps to settings.meta.app_id

# Meta Marketing API
BC_META__APP_ID=
BC_META__APP_SECRET=
BC_META__ACCESS_TOKEN=
BC_META__AD_ACCOUNT_ID=

# Anthropic (Claude) — used for prompt scoring LLM judge
BC_ANTHROPIC__API_KEY=

# Google Gemini
BC_GEMINI__API_KEY=

# Slack
BC_SLACK__BOT_TOKEN=
BC_SLACK__CHANNEL_OPS=#brand-conscience-ops
BC_SLACK__CHANNEL_APPROVALS=#brand-conscience-approvals

# Comet ML experiment tracking
BC_COMET__API_KEY=
BC_COMET__WORKSPACE=

# OPIK (optional for self-hosted)
BC_OPIK__API_KEY=
BC_OPIK__URL=http://localhost:8080

# Database
BC_DATABASE__URL=postgresql+psycopg://brand_conscience:brand_conscience@localhost:5432/brand_conscience

# Redis
BC_REDIS__URL=redis://localhost:6379/0

# Application
BC_APP_ENV=development
BC_LOG_LEVEL=INFO
BC_SAFETY__SPEND_APPROVAL_THRESHOLD=1000.0
BC_SAFETY__CIRCUIT_BREAKER_VELOCITY_MULTIPLIER=3.0
BC_SAFETY__CIRCUIT_BREAKER_COOLDOWN_MINUTES=60
